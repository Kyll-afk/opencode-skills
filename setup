#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$SCRIPT_DIR")"

echo ""
echo "  opencode-skills"
echo "  --------------"
echo ""

for skill in hm-init hm-architect hm-engineer hm-designer hm-qa hm-deploy hm-security hm-refactor hm-document hm-optimize; do
    target="$SKILLS_DIR/$skill"
    if [ -L "$target" ] || [ -e "$target" ]; then
        rm -rf "$target"
    fi
    ln -s "$SCRIPT_DIR/$skill" "$target"
    echo "  /$skill installed"
done

echo ""
echo "  Skills installed:"
echo ""
echo "    /hm-init         Start a new project"
echo "    /hm-architect    Design system architecture"
echo "    /hm-engineer     Validate code"
echo "    /hm-designer     Validate interface"
echo "    /hm-qa           Test everything"
echo "    /hm-deploy       Validate deploy and infra"
echo "    /hm-security     Security audit"
echo "    /hm-refactor     Code improvement"
echo "    /hm-document     Documentation"
echo "    /hm-optimize     Performance optimization"
echo ""
echo "  Done."
echo ""
